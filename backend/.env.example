# Port for the Node.js server (Railway automatically sets this, defaults to 5000 locally)
PORT=5000

# MongoDB Connection String (Atlas connection string in production, local URI in dev)
MONGO_URI=mongodb://127.0.0.1:27017/queue-cure

# Allowed Frontend URL for CORS (Point to your deployed Vercel URL in production)
FRONTEND_URL=http://localhost:5173
